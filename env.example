# Routing por tarea — cada una puede ir a un proveedor distinto
# Recomendado: scoring y extracción en DeepSeek (barato), chat en Claude (calidad)
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
# Opcional: forzar el routing (si no, se elige solo: barato para scoring, Claude para chat)
# SCORING_PROVIDER=deepseek
# CHAT_PROVIDER=anthropic
# EXTRACT_PROVIDER=deepseek

# ── Visión (lectura de imágenes/capturas de reservas) ──
# Por defecto, las imágenes se leen con Groq (gratis en su free tier).
# Modelo de visión por proveedor (opcional, ya trae defaults sensatos):
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# ANTHROPIC_VISION_MODEL=claude-haiku-4-5
# Nota: los PDF con texto se leen en el backend (pypdf), sin costo de LLM.

# ── Búsqueda web en vivo: News watcher + Destination Scanner ──
# Tavily (https://tavily.com) — 1000 búsquedas/mes gratis, sin tarjeta.
# Sin esta key, el scanner corre en modo mock (no busca nada) y el Companion
# solo usa la curación local. Con la key activa, el scheduler hace una pasada
# diaria por viaje (noticias/seguridad + recomendaciones del destino).
TAVILY_API_KEY=

# ── Lugares en vivo + geocodificación del hotel (Google Places API New) ──
# Sin esta key, "buscar cadena en vivo" y la geocodificación del hotel quedan
# en mock; las distancias caen al centroide de zona curada (siguen funcionando).
GOOGLE_MAPS_API_KEY=
