# Routing por tarea — cada una puede ir a un proveedor distinto
# Recomendado: scoring y extracción en DeepSeek (barato), chat en Claude (calidad)
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
# Opcional: forzar el routing (si no, se elige solo: barato para scoring, Claude para chat)
# SCORING_PROVIDER=deepseek
# CHAT_PROVIDER=anthropic
# EXTRACT_PROVIDER=deepseek

# ── Visión (lectura de imágenes/capturas de reservas) ──
# Por defecto, las imágenes se leen con Groq (gratis en su free tier).
# Modelo de visión por proveedor (opcional, ya trae defaults sensatos):
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# ANTHROPIC_VISION_MODEL=claude-haiku-4-5
# Nota: los PDF con texto se leen en el backend (pypdf), sin costo de LLM.
